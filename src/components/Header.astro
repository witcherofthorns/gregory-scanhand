---
import { navigation } from "../data/navigation.js"
import Button from "./Button.astro"
import IconHand from "../icons/IconHand.astro"

const button = { size:'medium', style:'primary' }
---

<div class="header">
    <div class="container wrap" id="noselect">
        <div class="label">
            <div class="logo">
                <IconHand />
            </div>
            <div>
                <p class="subtitle bold">ScanHand</p>
                <p class="caption gray">Хиромантия + AI · без регистрации</p>
            </div>
        </div>
        <div class="buttons">
            {navigation.map((data) => (
                <a class="button" href={data.path}>
                    <Button props={{ size: button.size, style: button.style, text:data.name}} />
                </a>
            ))}
        </div>
    </div>
</div>

<style>
.header{
    backdrop-filter: blur(12px);
    background: rgba(0,0,0,.35);
    border-bottom: 1px solid var(--color-border);
}
.header .container{
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 16px;
    padding-bottom: 16px;
    margin: auto;
}
.header .label{
    display: flex;
    gap: 16px;
    flex-direction: row;
}
.header .label .logo{
    width: 35px;
    height: 35px;
    min-width: 35px;
    border-radius: 10px;
    border: 1px solid var(--color-border-accent);
    box-shadow: 0 0 0 3px rgba(216,177,90,.10);
    display: flex;
    align-items: center;
    justify-content: center;
}
.header .buttons{
    display: inline-flex;
    flex-direction: row;
    gap: 8px;
}
</style>