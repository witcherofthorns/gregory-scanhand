---
import { faq } from "../data/faq.js";
import { focused } from "../data/focused";
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import Header from "../components/Header.astro";
import Radio from "../components/Radio.astro";
import Label from "../components/Label.astro";
import Accordion from "../components/Accordion.astro";
import Modal from "../components/Modal.astro";
import LoadingSpinner from "../components/LoadingSpinner.astro";
---

<Layout>
    <Header />
    <Label />
    <br /><br />

    <div class="index-container wrap">
        <div class="panel flex">
            <section class="col gap-26 panel-padding">
                <div class="header-text">
                    <h5>Загрузите фото ладоней</h5>
                    <p class="gray">Форматы: JPG/PNG · до 10 МБ на файл</p>
                </div>

                <div class="col gap-12">
                    <div class="wrap-to-col gap-12">
                        <section class="panel flex col gap-16 panel-padding small">
                            <p class="caption gray">Фото левой ладони</p>
                            <div class="row gap-6">
                                <Button icon="/icons/camera.svg" text="Выбрать фото" flex id="leftUploadBtn" />
                            </div>
                            <div id="leftPreview" class="image-preview-container hidden" />
                            <input type="file" id="leftHandInput" accept="image/jpeg,image/png" class="hidden" capture />
                        </section>
                        <section class="panel flex col gap-16 panel-padding small">
                            <p class="caption gray">Фото правой ладони</p>
                            <div class="row gap-6">
                                <Button icon="/icons/camera.svg" text="Выбрать фото" flex id="rightUploadBtn" />
                            </div>
                            <div id="rightPreview" class="image-preview-container hidden" />
                            <input type="file" id="rightHandInput" accept="image/jpeg,image/png" class="hidden" capture />
                        </section>
                    </div>
                    <section class="panel col gap-16 panel-padding small flex">
                        <p class="caption gray">Тема предсказания</p>
                        <Radio array={focused} id="themeSelector" />
                    </section>
                    <section class="panel col gap-16 panel-padding small flex">
                        <Button text="Получить предсказание" flex primary id="predictBtn" disabled />
                    </section>
                </div>
            </section>
        </div>
        <div class="panel flex">
            <section class="panel-padding index-panel-faq">
                <div class="header-text">
                    <h5>Вопросы и ответы</h5>
                    <p class="gray">
                        Коротко о том, как работает сервис и какие фото подойдут
                        для точного чтения
                    </p>
                </div>
                <div class="list">
                    {faq.map((data) => <Accordion props={data} />)}
                </div>
            </section>
        </div>
    </div>

    <Modal id="resultModal" title="Результат">
        <div id="loadingContainer">
            <LoadingSpinner text="Анализируем линии руки..." size="medium" />
        </div>
        <div id="resultContainer" class="result-container hidden">
            <div id="predictionContent"></div>
        </div>
    </Modal>

    <br /><br />
</Layout>

<style>
.index-container{
	gap: 20px;
	margin: auto;
	display: flex;
	flex-direction: row;
}
.index-container .panel-section{
	padding: 16px;
}
.index-panel-faq{
	display: flex;
	flex-direction: column;
	gap: 26px;
}
.header-text{
	display: flex;
	flex-direction: column;
	padding: 0px 8px;
	gap: 12px;
}
.index-panel-faq .list{
	display: flex;
	flex-direction: column;
	gap: 8px;
}
@media screen and (max-width: 960px) {
    .index-container{
        flex-direction: column;
    }
}

.hidden {
    display: none;
}
.image-preview-container {
    margin-top: 12px;
    text-align: center;
}
.result-container {
    width: 100%;
}
.wrap-to-col {
    display: flex;
    gap: 12px;
}
.prediction-text {
    line-height: 1.7;
    font-size: 16px;
    color: #374151;
    background: #f9fafb;
    padding: 20px;
    border-radius: 12px;
    margin-bottom: 20px;
    white-space: pre-wrap;
}
@media (max-width: 768px) {
    .wrap-to-col {
        flex-direction: column;
    }
}
.result-content{
    display: flex;
    flex-direction: column;
    gap: 36px;
}
.result-content .block{
    display: flex;
    flex-direction: column;
    gap: 16px;
}
</style>

<script src="/src/scripts/index.js" lang="js" />