---
import { faq } from '../data/faq.js' 
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Label from '../components/Label.astro';
import Accordion from '../components/Accordion.astro';
---

<Layout>
	<Header />
	<Label />
	<br/><br/>
	<div class="index-container wrap">
		<div class="panel flex">
			<section class="index-panel-content">

			</section>
		</div>
		<div class="panel flex">
			<section class="index-panel-content index-panel-faq">
				<div class="header">
					<h5>Вопросы и ответы</h5>
					<p class="gray">Коротко о том, как работает сервис и какие фото подойдут для точного чтения</p>
				</div>
				<div class="list">
            		{faq.map((data) => (
            		    <Accordion props={ data } />
            		))}
				</div>
			</section>
		</div>
	</div>
</Layout>

<style>
.index-container{
	gap: 20px;
	margin: auto;
	display: flex;
	flex-direction: row;
}
.index-panel-content{
	padding: 26px;
}
.index-panel-faq{
	display: flex;
	flex-direction: column;
	gap: 26px;
}
.index-panel-faq .header{
	display: flex;
	flex-direction: column;
	padding: 0px 8px;
	gap: 12px;
}
.index-panel-faq .list{
	display: flex;
	flex-direction: column;
	gap: 8px;
}

@media screen and (max-width: 1120px) {
    .index-container{
        flex-direction: column;
    }
}
</style>